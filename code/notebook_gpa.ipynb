   "source": [
    "# GPA Academic Level\n",
    "\n",
    "Reads a GPA from the user and prints its academic level.\n",
    "Uses the `gpa_level` function from `gpa.py`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [],
   "source": [
    "from gpa import gpa_level"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "gpa = float(input(\"Enter GPA: \"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "For GPA 3.200 Result: Passing\n"
     ]
    }
   ],
   "source": [
    "result = gpa_level(gpa)\n",
    "print(f\"For GPA {gpa:.3f} Result: {result}\")"
   ]
  },
