{
  "name": "IST356 Test Assignment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [28888, 28501, 28000],
  "portsAttributes": {
    "28888": { "label": "Jupyter" },
    "28501": { "label": "Streamlit" },
    "28000": { "label": "FastAPI" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}